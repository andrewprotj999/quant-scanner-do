# ═══════════════════════════════════════════════════════════
# Memecoin Scanner — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── SERVER ──────────────────────────────────────────────────
# Port for the Express API server
PORT=3001

# API key for authenticating requests (leave empty for open access)
# Generate one: openssl rand -hex 32
API_KEY=

# ─── ENGINE ──────────────────────────────────────────────────
# Scan interval in milliseconds (default: 30000 = 30 seconds)
SCAN_INTERVAL_MS=30000

# Maximum number of open positions at once
MAX_POSITIONS=10

# Auto-start the engine when the server boots (true/false)
AUTO_START=true

# ─── NOTIFICATIONS ───────────────────────────────────────────
# Telegram bot token (get from @BotFather on Telegram)
# 1. Message @BotFather on Telegram
# 2. Send /newbot and follow prompts
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=

# Telegram chat ID (get from @userinfobot on Telegram)
# 1. Message @userinfobot on Telegram
# 2. It will reply with your chat ID
# 3. Copy the number here
TELEGRAM_CHAT_ID=

# Discord webhook URL (optional, alternative to Telegram)
# 1. Go to your Discord server settings → Integrations → Webhooks
# 2. Create a new webhook and copy the URL
DISCORD_WEBHOOK_URL=

# ─── DATABASE ────────────────────────────────────────────────
# SQLite database file path (default: ./data/scanner.db)
# For production, use an absolute path
DATABASE_PATH=./data/scanner.db

# ─── FRONTEND ────────────────────────────────────────────────
# URL where the frontend is deployed (for CORS)
FRONTEND_URL=http://localhost:5173

# ─── ADVANCED ────────────────────────────────────────────────
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Node.js options (set in PM2 or systemd, not here)
# NODE_OPTIONS=--max-old-space-size=256
